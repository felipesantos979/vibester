generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Event {
  id              String   @id @default(uuid())
  name            String
  photoUrl        String
  category        String
  organizer       String
  location        String
  startDate       DateTime
  endDate         DateTime
  ticketLink      String?
  totalConfirmed  Int      @default(0)
  latitude        Float
  longitude       Float
  establishmentId String   @default(uuid())
  isFeatured      Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
