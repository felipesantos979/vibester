# URL base da API real do Vibester (sem barra no final)
VITE_API_BASE_URL=https://api.vibester.com.br

# PROVISÓRIO: a API ainda não tem vínculo conta -> estabelecimento.
# Se você souber o ID (uuid) do estabelecimento que esse painel administra,
# coloque aqui. Se deixar vazio, o painel busca o primeiro estabelecimento
# retornado por GET /establishment/establishments e usa ele.
# Troque esta variável assim que o backend tiver login de "dono de bar" de verdade.
VITE_ESTABLISHMENT_ID=
