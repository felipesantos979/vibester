# ── VPS / Produção ──────────────────────────────────────────────
# Defina apenas API_BASE para usar o gateway do Traefik em api.vibester.com.br
# O prefixo de cada serviço é adicionado automaticamente.
#
# Exemplo:
API_BASE=https://api.vibester.com.br

# ── Desenvolvimento local (alternativa ao API_BASE) ──────────────
# Se API_BASE não estiver definido, as variáveis abaixo são usadas.
# AUTH_URL=http://localhost:3001
# USER_URL=http://localhost:3003
# POST_URL=http://localhost:3000
# FEED_URL=http://localhost:3006
# EVENT_URL=http://localhost:3334
# ESTABLISHMENT_URL=http://localhost:3002
# SCRAPPING_URL=http://localhost:3005
